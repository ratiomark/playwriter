{
  "$schema": "https://holocron.so/docs.json",
  "name": "Playwriter",
  "description": "Docs for Playwriter, the CLI and MCP that lets agents control your real Chrome browser.",
  "logo": {
    "light": "/playwriter-logo.svg",
    "dark": "/playwriter-logo.svg",
    "href": "/"
  },
  "favicon": {
    "light": "/favicon-32.png",
    "dark": "/favicon-32.png"
  },
  "colors": {
    "primary": "#FF9500",
    "light": "#FF9500",
    "dark": "#FF9500"
  },
  "knownPaths": ["/README", "/api/*", "/login", "/dashboard", "/device"],
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "icon": "lucide:book",
        "groups": [
          {
            "group": "Getting Started",
            "icon": "lucide:rocket",
            "pages": [
              "index",
              "docs/installation",
              "docs/quick-start",
              "docs/cli",
              "docs/mcp-setup"
            ]
          },
          {
            "group": "Features",
            "icon": "lucide:sparkles",
            "pages": [
              "docs/snapshots",
              "docs/visual-labels",
              "docs/sessions",
              "docs/debugger",
              "docs/network",
              "docs/recording",
              "docs/streaming",
              "docs/headless",
              "docs/profiling",
              "docs/security"
            ]
          },
          {
            "group": "Guides",
            "icon": "lucide:book-open",
            "pages": ["docs/remote-access", "docs/use-cases", "docs/troubleshooting"]
          },
          {
            "group": "Comparison",
            "icon": "lucide:git-compare",
            "pages": [
              "docs/vs-chrome-cdp",
              "docs/vs-playwright-mcp",
              "docs/vs-playwright-cli",
              "docs/vs-browser-mcp",
              "docs/vs-claude-extension"
            ]
          },
          {
            "group": "Reference",
            "icon": "lucide:book-text",
            "pages": ["docs/skill", "docs/configuration"]
          }
        ]
      },
      {
        "tab": "Cloud Browsers",
        "icon": "lucide:dollar-sign",
        "pages": ["docs/cloud-browsers"]
      },
      {
        "tab": "Changelog",
        "icon": "lucide:newspaper",
        "changelog": "https://github.com/remorses/playwriter",
        "initialContent": "changelog/intro"
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/remorses/playwriter",
          "placement": "tabs"
        }
      ]
    }
  },
  "navbar": {
    "primary": {
      "label": "Cloud Login",
      "href": "/dashboard"
    }
  },
  "footer": {
    "links": [
      {
        "header": "platform",
        "items": [
          { "label": "Rent Cloud Browsers", "href": "/dashboard" },
          { "label": "GitHub", "href": "https://github.com/remorses/playwriter" },
          {
            "label": "Chrome Extension",
            "href": "https://chromewebstore.google.com/detail/playwriter/jfeammnjpkecdekppnclgkkffahnhfhe"
          }
        ]
      }
    ],
    "socials": {
      "github": "https://github.com/remorses/playwriter"
    }
  }
}
